{
  "name": "agent-council",
  "version": "0.5.1",
  "description": "1 human + N AI agents collaborating naturally in a Telegram group chat",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "cli": "node dist/index.js --adapter=cli",
    "cli:verbose": "node dist/index.js --adapter=cli --verbose",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google/genai": "^1.49.0",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "dotenv": "^16.4.0",
    "grammy": "^1.35.0",
    "openai": "^6.34.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
